{
  "name": "@chronocide/spider",
  "version": "4.0.0",
  "description": "Tiny static site generator",
  "author": "Chronocide",
  "license": "GPL-3.0",
  "type": "module",
  "types": "dist/spider.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": "./dist/spider.js"
  },
  "keywords": [
    "html",
    "generator",
    "static",
    "site"
  ],
  "files": [
    "dist/**/*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chronoDave/spider.git"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "scripts": {
    "lint": "eslint src",
    "lint:tsc": "tsc --noEmit",
    "build": "node scripts/build.ts",
    "test": "node --test src/**/*.spec.ts",
    "preversion": "npm run lint:tsc && npm run lint && npm run test && npm run build",
    "version": "git add -A dist",
    "postversion": "git push && git push --tags"
  },
  "devDependencies": {
    "@chronocide/eslint-config": "0.8.1",
    "@chronocide/spark": "^0.4.1",
    "@types/node": "^25.6.0",
    "dts-bundle-generator": "^9.5.1",
    "esbuild": "^0.25.5",
    "typescript": "^6.0.3"
  }
}
